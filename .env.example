# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./suelotto.db

# ─── Security ─────────────────────────────────────────────────────
JWT_SECRET=genera-una-clave-segura-aqui-con-secrets-token-hex-32
JWT_EXPIRE_MINUTES=60
PASSWORD_MIN_LENGTH=8
ALLOWED_ORIGINS=http://localhost:8501,https://tu-dominio.com
ADMIN_API_TOKEN=token-seguro-para-el-admin

# ─── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW=300

# ─── SMTP (Email) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
SMTP_FROM=noreply@suenalotto.com
APP_URL=http://localhost:8501

# ─── Qvapay (Payment) ────────────────────────────────────────────
QVAPAY_API_URL=https://qvapay.com/api/v1
QVAPAY_APP_ID=tu-app-id
QVAPAY_SECRET=tu-secreto
QVAPAY_WEBHOOK_SECRET=tu-webhook-secret

# ─── Promo Lifetime ─────────────────────────────────────────────
# Precio promocional para primeros N usuarios que compren Lifetime
PROMO_LIFETIME_PRICE=50.00
PROMO_MAX_USERS=100

# ─── Score Weights (Multi-Game Hybrid) ──────────────────────────
# Pesos del score compuesto multi-juego (Pick 3 + Pick 4, E + M)
# Todos los juegos de Florida Lottery se combinan en una estadística única
# SCORE_W_FREQ_MULTI: frecuencia del par en TODOS los juegos (90d) — peso 0.15
# SCORE_W_REC_MULTI:  recencia (1/sqrt(1+dias)) — peso 0.30
# SCORE_W_FREQ_7D_MULTI: frecuencia del par en últimos 7 días (todos los juegos) — peso 0.15
# SCORE_W_FREQ_DIGITOS: frecuencia de los dígitos 0-9 que componen el par — peso 0.15
# SCORE_W_TREND: tendencia (cambio últimos 15d vs 15d anteriores) — peso 0.25
# SCORE_W_ML: predicción ML (desactivado por defecto, no mejora pares) — peso 0.00
SCORE_W_FREQ_MULTI=0.15
SCORE_W_REC_MULTI=0.30
SCORE_W_FREQ_7D_MULTI=0.15
SCORE_W_FREQ_DIGITOS=0.15
SCORE_W_TREND=0.25
SCORE_W_ML=0.00
SCORE_MIN_FREQ=0
SCORE_MAX_DAYS=365

# ─── Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=tu-api-key-de-gemini

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=data/suenalotto.log
